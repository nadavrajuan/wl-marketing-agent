BIGQUERY_PROJECT_ID=weightagent
BIGQUERY_DATASET=WeightAgent
GOOGLE_ADS_DATASET=GoogleAds
BING_ADS_DATASET=BingAds
ANALYTICS_WL_DATASET=analytics_wl
# Optional if the Google Ads transfer customer suffix changes:
# GOOGLE_ADS_CUSTOMER_SUFFIX=4808949235
BIGQUERY_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"replace_me"}
# Optional alternative to BIGQUERY_SERVICE_ACCOUNT_JSON:
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/bigquery-service-account.json
DATABASE_URL=postgresql://postgres:replace_me@localhost:5432/wl_marketing
COMPETITOR_SYNC_TOKEN=replace_me
COMPETITOR_HISTORY_RETENTION_DAYS=14
# Optional: write raw HTML + parsed JSON snapshots to a mounted directory for git/archive workflows
# COMPETITOR_ARCHIVE_DIR=/var/data/competitor-landscape

NEXT_PUBLIC_AGENT_BASE_URL=/agent/

# Research Agent — internal URL to reach the FastAPI agent service
# Dev: http://localhost:8001   Docker: http://agent:8003
AGENT_INTERNAL_URL=http://localhost:8001
# Must match INGEST_API_TOKEN in the agent .env
INGEST_API_TOKEN=replace_me
